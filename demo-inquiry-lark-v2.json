                  {
                    "name": "Content-Type",
                    "value": "application/json; charset=utf-8"
                  }
                ],
                "qs": [],
                "bodyType": "raw",
                "parseResponse": true,
                "contentType": "application/json",
                "body": "{\"receive_id\":\"oc_63332f5e478f265af7db9f0ec9c89ed3\",\"msg_type\":\"interactive\",\"content\":\"{\\\"elements\\\":[[{\\\"tag\\\":\\\"div\\\",\\\"text\\\":{\\\"tag\\\":\\\"lark_md\\\",\\\"content\\\":\\\"**New Inquiry**\\\\n\\\\nName: **{{1.name}}** ({{1.company}})\\\\nEmail: {{1.email}}\\\\n\\\\nCategory: **{{3.category}}** | Priority: {{3.priority}}/5\\\\nSummary: {{3.summary}}\\\\n\\\\nRecommended: {{3.suggested_action}}\\\"}}]]}\"}"
              },
              "metadata": {
                "designer": {
                  "x": 1500,
                  "y": 0
                }
              }
            }
          ]
        },
        {
          "flow": [
            {
              "id": 9,
              "module": "http:ActionSendData",
              "version": 1,
              "parameters": {
                "handleErrors": false
              },
              "mapper": {
                "url": "https://open.larksuite.com/open-apis/auth/v3/tenant_access_token/internal",
                "method": "post",
                "headers": [
                  {
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "qs": [],
                "bodyType": "raw",
                "parseResponse": true,
                "contentType": "application/json",
                "body": "{\"app_id\": \"cli_a9156da34e789e1b\", \"app_secret\": \"cJRbg1SiPiOwm7H8QSOCIe7VWeGyAQUM\"}"
              },
              "metadata": {
                "designer": {
                  "x": 1200,
                  "y": 200
                }
              }
            },
            {
              "id": 10,
              "module": "http:ActionSendData",
              "version": 1,
              "parameters": {
                "handleErrors": false
              },
              "mapper": {
                "url": "https://open.larksuite.com/open-apis/calendar/v4/calendars/feishu.cn_cBT8dKAhsLqBUxKpjeNpsg@group.calendar.feishu.cn/events",
                "method": "post",
                "headers": [
                  {
                    "name": "Authorization",
                    "value": "Bearer {{9.data.tenant_access_token}}"
                  },
                  {
                    "name": "Content-Type",
                    "value": "application/json; charset=utf-8"
                  }
                ],
                "qs": [],
                "bodyType": "raw",
                "parseResponse": true,
                "contentType": "application/json",
                "body": "{\"summary\":\"Inquiry Follow-up: {{1.company}}\",\"description\":\"Name: {{1.name}}\\nEmail: {{1.email}}\\nCategory: {{3.category}} | Priority: {{3.priority}}/5\\nSummary: {{3.summary}}\\nRecommended: {{3.suggested_action}}\",\"start_time\":{\"timestamp\":\"{{3.meeting_start}}\"},\"end_time\":{\"timestamp\":\"{{3.meeting_end}}\"},\"need_notification\":true}"
              },
              "metadata": {
                "designer": {
                  "x": 1500,
                  "y": 200
                }
              }
            }
          ],
          "label": "Calendar Booking (sales/urgent only)",
          "filter": {
            "name": "needs_meeting = true",
            "conditions": [
              [
                {
                  "a": "{{3.needs_meeting}}",
                  "b": "true",
                  "o": "text:equal"
                }
              ]
            ]
          }
        }
      ]
    }
  ],
  "metadata": {
    "instant": true,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": {
      "orphans": []
    },
    "zone": "eu1.make.com"
  }
}
