              },
              "mapper": {
                "url": "https://open.larksuite.com/open-apis/auth/v3/tenant_access_token/internal",
                "method": "post",
                "headers": [
                  {
                    "name": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "qs": [],
                "bodyType": "raw",
                "parseResponse": true,
                "contentType": "application/json",
                "body": "{\"app_id\": \"cli_a9156da34e789e1b\", \"app_secret\": \"cJRbg1SiPiOwm7H8QSOCIe7VWeGyAQUM\"}"
              },
              "metadata": {
                "designer": {
                  "x": 1200,
                  "y": 0
                }
              }
            },
            {
