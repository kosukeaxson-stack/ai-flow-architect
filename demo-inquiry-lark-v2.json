{
  "name": "AIFLOW Demo - AI Auto-Classification & Calendar Booking (Lark)",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": null,
        "maxResults": 1
      },
      "mapper": {},
      "metadata": {
        "designer": {
          "x": 0,
          "y": 0
        },
        "restore": {
          "parameters": {
            "hook": {
              "label": "AIFLOW Demo Inquiry Webhook"
            }
          }
        },
        "expect": [
          {
            "name": "name",
            "type": "text",
            "label": "Name"
          },
          {
            "name": "email",
            "type": "text",
            "label": "Email"
          },
          {
            "name": "company",
            "type": "text",
            "label": "Company"
          },
          {
            "name": "message",
            "type": "text",
            "label": "Inquiry"
          }
        ]
      }
    },
    {
      "id": 2,
      "module": "openai-gpt-3:CreateCompletion",
      "version": 1,
      "parameters": {
        "__IMTCONN__": 5430347
      },
      "mapper": {
        "select": "chat",
        "temperature": "0.1",
        "top_p": "1",
        "n_completions": "1",
        "model": "gpt-4o-mini",
        "max_tokens": 250,
        "messages": [
          {
            "role": "system",
            "content": "You are an inquiry classification AI. Reply ONLY in JSON format: {\"category\": \"urgent|normal|sales|support\", \"summary\": \"30 chars max\", \"priority\": 1-5, \"suggested_action\": \"recommended action\", \"needs_meeting\": true or false}. Set needs_meeting=true ONLY for sales or urgent category.",
            "imageDetail": "auto"
          },
          {
            "role": "user",
            "content": "Name: {{1.name}}\nCompany: {{1.company}}\nEmail: {{1.email}}\nInquiry: {{1.message}}",
            "imageDetail": "auto"
          }
        ],
        "response_format": "json_object",
        "parseJSONResponse": true
      },
      "metadata": {
        "designer": {
          "x": 300,
          "y": 0
        },
        "restore": {
          "parameters": {
            "__IMTCONN__": {
              "label": "My OpenAI connection",
              "data": {
                "scoped": "true",
                "connection": "openai-gpt-3"
              }
            }
          },
          "expect": {
            "select": {
              "label": "Create a Chat Completion (GPT and o1 models)"
            },
            "model": {
              "mode": "chose",
              "label": "gpt-4o-mini"
            },
            "messages": {
              "mode": "chose",
              "items": [
                {
                  "role": {
                    "mode": "chose",
                    "label": "Developer / System"
                  },
                  "imageDetail": {
                    "mode": "chose",
                    "label": "Auto"
                  }
                },
                {
                  "role": {
                    "mode": "chose",
                    "label": "User"
                  },
                  "imageDetail": {
                    "mode": "chose",
                    "label": "Auto"
                  }
                }
              ]
            },
            "response_format": {
              "mode": "chose",
              "label": "JSON Object"
            },
            "parseJSONResponse": {
              "mode": "chose"
            }
          }
        }
      }
    },
    {
      "id": 3,
      "module": "util:SetVariables",
      "version": 1,
      "parameters": {},
      "mapper": {
        "scope": "roundtrip",
        "variables": [
          {
            "name": "category",
            "value": "{{2.result.category}}"
          },
          {
            "name": "summary",
            "value": "{{2.result.summary}}"
          },
          {
            "name": "priority",
            "value": "{{2.result.priority}}"
          },
          {
            "name": "suggested_action",
            "value": "{{2.result.suggested_action}}"
          },
          {
            "name": "needs_meeting",
            "value": "{{2.result.needs_meeting}}"
          },
          {
            "name": "timestamp",
            "value": "{{formatDate(now; \"YYYY-MM-DD HH:mm\")}}"
          },
          {
            "name": "meeting_start",
            "value": "{{formatDate(setHour(setMinute(setSecond(addDays(now; 1); 0); 0); 10); \"X\")}}"
          },
          {
            "name": "meeting_end",
            "value": "{{formatDate(setHour(setMinute(setSecond(addDays(now; 1); 0); 30); 10); \"X\")}}"
          }
        ]
      },
      "metadata": {
        "designer": {
          "x": 600,
          "y": 0
        }
      }
    },
    {
      "id": 4,
      "module": "builtin:BasicRouter",
      "version": 1,
      "parameters": {},
      "mapper": null,
      "metadata": {
        "designer": {
          "x": 900,
          "y": 0
        }
      },
      "routes": [
        {
          "flow": [
            {
              "id": 5,
              "module": "http:ActionSendData",
              "version": 1,
              "parameters": {
